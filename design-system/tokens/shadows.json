        "$value": "none",
        "$description": "No shadow in dark mode"
      }
    },
    "level-1": {
      "light": {
        "$type": "shadow",
        "$value": [
          {
            "offsetX": "0px",
            "offsetY": "1px",
            "blur": "2px",
            "spread": "0px",
            "color": "rgba(0, 0, 0, 0.05)"
          }
        ],
        "$description": "Subtle shadow for slight separation"
      },
      "dark": {
        "$type": "shadow",
        "$value": [
          {
            "offsetX": "0px",
            "offsetY": "1px",
            "blur": "3px",
            "spread": "0px",
            "color": "rgba(0, 0, 0, 0.5)"
          }
        ],
